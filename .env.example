# ============================================================================
# CloudAI Fusion - Environment Variables
# ============================================================================
# IMPORTANT: Do NOT use this file directly in production!
# Generate a secure .env with: scripts/env-generate.sh (or .bat)
#
#   Development:   scripts/env-generate.sh --profile dev
#   Staging:       scripts/env-generate.sh --profile staging
#   Production:    scripts/env-generate.sh --profile prod
#
# SECURITY: Never commit .env to version control!
# ============================================================================

# --------------------------------------------------------------------------
# Environment
# --------------------------------------------------------------------------
CLOUDAI_ENV=development
CLOUDAI_LOG_LEVEL=debug

# --------------------------------------------------------------------------
# Database (PostgreSQL) — REQUIRED
# --------------------------------------------------------------------------
CLOUDAI_DB_PASSWORD=cloudai_secret
# CLOUDAI_DB_SSLMODE=disable

# --------------------------------------------------------------------------
# Authentication — REQUIRED
# --------------------------------------------------------------------------
# Generate a strong random key (32+ bytes):
#   openssl rand -hex 32
CLOUDAI_JWT_SECRET=change-this-to-a-strong-random-key-at-least-32-bytes

# --------------------------------------------------------------------------
# Grafana Admin Password (optional, defaults to 'cloudai')
# --------------------------------------------------------------------------
GF_ADMIN_PASSWORD=cloudai

# --------------------------------------------------------------------------
# Redis Password (optional, empty by default)
# --------------------------------------------------------------------------
# CLOUDAI_REDIS_PASSWORD=

# --------------------------------------------------------------------------
# LLM Integration (optional — set API keys to enable generative AI)
# --------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o
# DASHSCOPE_API_KEY=sk-...
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_MODEL=qwen-max
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3:8b
# VLLM_BASE_URL=http://localhost:8000/v1
# VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# --------------------------------------------------------------------------
# Monitoring (optional)
# --------------------------------------------------------------------------
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# --------------------------------------------------------------------------
# Feature Profile & Flags
# --------------------------------------------------------------------------
# Profile: minimal | standard (default) | full
#   minimal  — Core only (API/Scheduler/Agent + DB/Redis). Fastest startup.
#   standard — Production-ready features (monitoring, edge, security, cost).
#   full     — All features including experimental (GPU sharing, RL, LLM ops).
CLOUDAI_FEATURE_PROFILE=standard

# Per-flag overrides (true/false). These override the profile setting.
# Format: CLOUDAI_FF_<FLAG_KEY>=true|false
#
# Compute:
# CLOUDAI_FF_GPU_SHARING_MPS=false
# CLOUDAI_FF_GPU_SHARING_MIG=false
# CLOUDAI_FF_TOPOLOGY_AWARE_SCHEDULING=true
# CLOUDAI_FF_WASM_RUNTIME=true
# CLOUDAI_FF_EDGE_COMPUTING=true
#
# AI:
# CLOUDAI_FF_RL_SCHEDULER=false
# CLOUDAI_FF_AUTO_SCALING=false
# CLOUDAI_FF_LLM_OPERATIONS_AGENT=false
# CLOUDAI_FF_AIOPS_SELF_HEALING=false
# CLOUDAI_FF_CAPACITY_PLANNING=false
#
# Networking:
# CLOUDAI_FF_SERVICE_MESH=true
# CLOUDAI_FF_GRPC_INTERNAL=false
# CLOUDAI_FF_WEBSOCKET_EVENTS=true
#
# Observability:
# CLOUDAI_FF_DISTRIBUTED_TRACING=true
# CLOUDAI_FF_ADVANCED_MONITORING=true
# CLOUDAI_FF_AUDIT_LOGGING=true
#
# Security:
# CLOUDAI_FF_ADVANCED_THREAT_DETECTION=true
# CLOUDAI_FF_COMPLIANCE_SCANNING=true
#
# FinOps:
# CLOUDAI_FF_COST_OPTIMIZATION=true
# CLOUDAI_FF_SPOT_INSTANCE_MGMT=false
# CLOUDAI_FF_RESERVED_INSTANCE_ADVISOR=false
#
# Platform:
# CLOUDAI_FF_MULTI_CLUSTER=false
# CLOUDAI_FF_GITOPS=false
# CLOUDAI_FF_PLUGIN_ECOSYSTEM=true
# CLOUDAI_FF_MULTI_TENANCY=true
# CLOUDAI_FF_DISASTER_RECOVERY=false

# --------------------------------------------------------------------------
# GPU / AI Device (optional)
# --------------------------------------------------------------------------
# AI_DEVICE: cpu (default, all platforms), cuda (Linux/Windows WSL2), mps (macOS Apple Silicon)
# AI_DEVICE=cpu
# GPU_COUNT=all
# CUDA_VISIBLE_DEVICES=all
# NVIDIA_VISIBLE_DEVICES=all
# PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# --------------------------------------------------------------------------
# Debug Endpoints Security
# --------------------------------------------------------------------------
# CLOUDAI_DEBUG_ENABLED: Must be explicitly "true" to enable /debug/* endpoints.
# Default: disabled (safe default). Even when enabled, requires JWT admin token.
CLOUDAI_DEBUG_ENABLED=false
#
# CLOUDAI_DEBUG_ALLOWED_IPS: Optional IP allowlist (comma-separated IPs/CIDRs).
# When set, only requests from these IPs can access debug endpoints.
# Example: 127.0.0.1,10.0.0.0/8,192.168.0.0/16
# CLOUDAI_DEBUG_ALLOWED_IPS=127.0.0.1,::1
