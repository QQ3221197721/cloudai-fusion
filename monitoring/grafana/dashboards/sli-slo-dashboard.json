{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 2,
  "id": null,
  "links": [
    { "title": "Platform Overview", "url": "/d/cloudai-fusion-overview", "type": "link" }
  ],
  "panels": [
    {
      "title": "Service Availability (SLO)",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "cloudai_slo_availability_ratio{service=\"$service\"}", "legendFormat": "{{ service }}" }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0.99, "max": 1, "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.995 },
              { "color": "green", "value": 0.999 }
            ]
          }
        }
      }
    },
    {
      "title": "Error Budget Remaining",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "expr": "cloudai_slo_error_budget_remaining_ratio{service=\"$service\"}", "legendFormat": "{{ service }}" }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1, "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.25 },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.75 }
            ]
          }
        }
      }
    },
    {
      "title": "Burn Rate (Multi-Window)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "cloudai_slo_burn_rate{service=\"$service\"}", "legendFormat": "{{ window }}" }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "thresholdsStyle": { "mode": "line" } },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "orange", "value": 6 },
              { "color": "red", "value": 14.4 }
            ]
          }
        }
      }
    },
    {
      "title": "Latency SLO (p99 vs Target)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(cloudai_sli_latency_seconds_bucket{service=\"$service\"}[5m])))", "legendFormat": "p99 actual" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(cloudai_sli_latency_seconds_bucket{service=\"$service\"}[5m])))", "legendFormat": "p95 actual" },
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(cloudai_sli_latency_seconds_bucket{service=\"$service\"}[5m])))", "legendFormat": "p50 actual" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Latency Target Met",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 6 },
      "targets": [
        { "expr": "cloudai_slo_latency_target_met{service=\"$service\",percentile=\"p99\"}", "legendFormat": "p99" },
        { "expr": "cloudai_slo_latency_target_met{service=\"$service\",percentile=\"p95\"}", "legendFormat": "p95" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "0": { "text": "MISS", "color": "red" }, "1": { "text": "MET", "color": "green" } } }]
        }
      }
    },
    {
      "title": "Request Rate (QPS)",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 6 },
      "targets": [
        { "expr": "sum(rate(cloudai_sli_requests_total{service=\"$service\"}[5m]))", "legendFormat": "total" },
        { "expr": "sum(rate(cloudai_sli_requests_total{service=\"$service\",result=\"error\"}[5m]))", "legendFormat": "errors" }
      ]
    },
    {
      "title": "HTTP Golden Signals - Traffic",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        { "expr": "sum by (method) (rate(cloudai_http_requests_total[5m]))", "legendFormat": "{{ method }}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "HTTP Golden Signals - Errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        { "expr": "sum by (error_type) (rate(cloudai_http_errors_total[5m]))", "legendFormat": "{{ error_type }}" },
        { "expr": "sum(rate(cloudai_http_errors_total{error_type=\"server_error\"}[5m])) / sum(rate(cloudai_http_requests_total[5m]))", "legendFormat": "5xx rate" }
      ]
    },
    {
      "title": "HTTP In-Flight Requests",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 22 },
      "targets": [
        { "expr": "cloudai_http_requests_in_flight", "legendFormat": "in-flight" }
      ]
    },
    {
      "title": "Goroutines",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 22 },
      "targets": [
        { "expr": "cloudai_runtime_goroutines_count", "legendFormat": "goroutines" }
      ]
    },
    {
      "title": "DB Pool Utilization",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 22 },
      "targets": [
        { "expr": "cloudai_pool_utilization_ratio", "legendFormat": "{{ pool_name }}" }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1, "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      }
    },
    {
      "title": "Task Success Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 28 },
      "targets": [
        { "expr": "cloudai:task:success_rate:10m", "legendFormat": "success rate" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "title": "Scheduling Latency p95",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 28 },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(cloudai_scheduler_scheduling_latency_seconds_bucket[5m]))", "legendFormat": "p95" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Total Hourly Cost",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 28 },
      "targets": [
        { "expr": "cloudai:cost:total_hourly", "legendFormat": "hourly" }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } }
    },
    {
      "title": "Cost Per Cluster",
      "type": "bargauge",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 28 },
      "targets": [
        { "expr": "cloudai:cost:per_cluster_hourly", "legendFormat": "{{ cluster_id }}" }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["cloudai-fusion", "slo", "sli", "golden-signals"],
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "query": "label_values(cloudai_slo_availability_ratio, service)",
        "datasource": "Prometheus",
        "current": { "text": "apiserver", "value": "apiserver" }
      }
    ]
  },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "CloudAI Fusion - SLI/SLO Dashboard",
  "uid": "cloudai-fusion-slo",
  "version": 1
}
